    agent any
 
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out PayFlow demo code from GitHub...'
            }
        }
        stage('Build') {
            steps {
                echo 'Simulating build of PayFlow landing page...'
            }
        }
        stage('Test') {
            steps {
                echo 'Running placeholder tests...'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Simulating deployment to PayFlow staging server...'
            }
        }
    }
}
